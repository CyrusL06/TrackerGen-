                <UserObject label="&lt;span class=&quot;ͼv&quot;&gt;import&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;express&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;from&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼz&quot;&gt;&quot;express&quot;&lt;/span&gt;&lt;span&gt;;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;ͼv&quot;&gt;import&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;React&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;from&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼz&quot;&gt;&quot;react&quot;&lt;/span&gt;&lt;span&gt;;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;ͼv&quot;&gt;import&lt;/span&gt;&lt;span&gt; { &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;renderToPipeableStream&lt;/span&gt;&lt;span&gt; } &lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;from&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼz&quot;&gt;&quot;react-dom/server&quot;&lt;/span&gt;&lt;span&gt;;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;ͼv&quot;&gt;import&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;App&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;from&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼz&quot;&gt;&quot;./App.js&quot;&lt;/span&gt;&lt;span&gt;;&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span class=&quot;ͼv&quot;&gt;const&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;app&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;=&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;express&lt;/span&gt;&lt;span&gt;();&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span class=&quot;ͼ11&quot;&gt;app&lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;.&lt;/span&gt;&lt;span&gt;get(&lt;/span&gt;&lt;span class=&quot;ͼz&quot;&gt;&quot;/&quot;&lt;/span&gt;&lt;span&gt;, (&lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;req&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;res&lt;/span&gt;&lt;span&gt;) =&amp;gt; {&lt;/span&gt;&lt;br&gt;&lt;span&gt;  &lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;const&lt;/span&gt;&lt;span&gt; { pipe } &lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;=&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;renderToPipeableStream&lt;/span&gt;&lt;span&gt;(&lt;/span&gt;&lt;span class=&quot;ͼ13&quot;&gt;&amp;lt;App&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ13&quot;&gt;/&amp;gt;&lt;/span&gt;&lt;span&gt;, {&lt;/span&gt;&lt;br&gt;&lt;span&gt;    bootstrapScripts: [&lt;/span&gt;&lt;span class=&quot;ͼz&quot;&gt;&quot;/client.js&quot;&lt;/span&gt;&lt;span&gt;],&lt;/span&gt;&lt;br&gt;&lt;span&gt;    onShellReady() {&lt;/span&gt;&lt;br&gt;&lt;span&gt;      &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;res&lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;.&lt;/span&gt;&lt;span&gt;setHeader(&lt;/span&gt;&lt;span class=&quot;ͼz&quot;&gt;&quot;content-type&quot;&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼz&quot;&gt;&quot;text/html&quot;&lt;/span&gt;&lt;span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span&gt;      &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;pipe&lt;/span&gt;&lt;span&gt;(&lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;res&lt;/span&gt;&lt;span&gt;);&lt;/span&gt;&lt;br&gt;&lt;span&gt;    }&lt;/span&gt;&lt;br&gt;&lt;span&gt;  });&lt;/span&gt;&lt;br&gt;&lt;span&gt;});&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span class=&quot;ͼ11&quot;&gt;app&lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;.&lt;/span&gt;&lt;span&gt;listen(&lt;/span&gt;&lt;span class=&quot;ͼy&quot;&gt;3000&lt;/span&gt;&lt;span&gt;);&lt;/span&gt;" link="&lt;span class=&quot;ͼv&quot;&gt;import&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ11&quot;&gt;express&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼv&quot;&gt;from&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼz&quot;&gt;&quot;express&quot;&lt;/span&gt;&lt;span&gt